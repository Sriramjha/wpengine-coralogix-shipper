# Copy to .env and fill in values. Never commit .env.
#
# Load before running:  set -a && source .env && set +a
# Or use:              ./run.sh

# --- WP Engine (User Portal -> Profile -> API Access) ---
WPE_API_USER=
WPE_API_PASSWORD=
# Install UUID from GET https://api.wpengineapi.com/v1/installs (field "id"), not the short name
WPE_INSTALL_ID=

# Optional: default https://api.wpengineapi.com/v1 — the public API has no documented /installs/{id}/logs
# WPE_API_BASE=https://api.wpengineapi.com/v1
# If you have a custom logs HTTP API, set a template (query params type, limit, offset are still appended):
# WPE_LOGS_URL=https://example.com/api/installs/{install_id}/logs

# --- Coralogix (Send-Your-Data API key + domain from Coralogix UI) ---
CORALOGIX_PRIVATE_KEY=
CORALOGIX_DOMAIN=eu2.coralogix.com

CX_APPLICATION_NAME=WPENGINE
# Defaults to WPE_INSTALL_ID if empty
CX_SUBSYSTEM_NAME=

# --- Checkpoint (persist between runs) ---
STATE_PATH=./wpengine_coralogix_state.json

# --- Optional: skip overlapping runs (Linux/macOS, requires flock) ---
# LOCK_PATH=./wpengine_coralogix.lock

# --- Optional ---
# WPE_LOG_TYPES=access,error
# MAX_RECORDS_PER_RUN=5000
# PAGE_SIZE=100
# CORALOGIX_BATCH_SIZE=50
