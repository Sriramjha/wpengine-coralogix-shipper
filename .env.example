# Copy to .env and fill in values. Never commit .env.
#
# Load before running:  set -a && source .env && set +a
# Or use:              ./run.sh

# --- WP Engine (User Portal -> Profile -> API Access) ---
WPE_API_USER=
WPE_API_PASSWORD=
# Either the install UUID (from GET /v1/installs, field "id") OR the install
# short name (e.g. "mysite" from the User Portal). The shipper auto-resolves
# UUID -> short name and caches the resolution in the state file.
WPE_INSTALL_ID=

# Optional: default https://api.wpengineapi.com/v1
# WPE_API_BASE=https://api.wpengineapi.com/v1

# --- Coralogix (Send-Your-Data API key + domain from Coralogix UI) ---
CORALOGIX_PRIVATE_KEY=
CORALOGIX_DOMAIN=eu2.coralogix.com

CX_APPLICATION_NAME=WPENGINE
# Defaults to the resolved install short name if empty
CX_SUBSYSTEM_NAME=

# --- Checkpoint (persist between runs) ---
STATE_PATH=./wpengine_coralogix_state.json

# --- Optional: skip overlapping runs (Linux/macOS, requires flock) ---
# LOCK_PATH=./wpengine_coralogix.lock

# --- Optional: which platform-event streams to ship ---
# Comma-separated subset of: install,backups,domains,ssl,account_users,ssh_keys,usage,status
# (Default: all of them.)
# WPE_EVENT_TYPES=install,backups,domains,ssl,account_users,ssh_keys,usage,status

# --- Optional: tuning ---
# MAX_RECORDS_PER_RUN=5000     # cap items pulled per resource per run
# PAGE_SIZE=100                # WP Engine list pagination page size
# CORALOGIX_BATCH_SIZE=50      # singles batched per Coralogix HTTP call

# NOTE on logs: WP Engine's public Hosting Platform API has no access/error
# log endpoint (verified against GET /v1/swagger). This shipper polls the
# documented platform endpoints (install meta, backups, domains, SSL, users,
# SSH keys, usage, status) and emits one Coralogix event per change.
# For raw nginx/PHP logs, use SSH/SFTP, the Log Forwarding add-on, or a
# WordPress mu-plugin instead.
